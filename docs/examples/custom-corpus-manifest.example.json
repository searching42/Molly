  "documents": [
    {
      "document_id": "doc-example-001",
      "pdf_path": "/path/outside/git/doc-example-001.pdf",
      "pdf_sha256": "",
      "title": "Example Paper Title",
      "doi": "",
      "source_url": "",
      "license_or_access": "example-placeholder",
      "provenance_note": "Placeholder only; replace with local operator-owned metadata.",
      "allow_raw_pdf_commit": false,
      "allow_parsed_document_commit": false,
      "allow_mineru_bundle_commit": false,
      "redaction_required": true,
      "expected_document_type": "scientific_paper",
      "notes": ""
    }
  ]
}
