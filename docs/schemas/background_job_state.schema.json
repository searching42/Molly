      "required": [
        "checkpoint_id",
        "stage"
      ],
      "title": "BackgroundJobCheckpoint",
      "type": "object"
    },
    "RunStatus": {
      "enum": [
        "PENDING",
        "RUNNING",
        "WAITING_USER",
        "PAUSED_BY_USER",
        "SUCCEEDED",
        "DEGRADED",
        "FAILED",
        "SKIPPED",
        "CANCELLED",
        "DONE"
