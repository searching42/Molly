      },
      "title": "Checkpoints",
      "type": "array"
    },
    "resume_from_checkpoint_id": {
      "default": "",
      "title": "Resume From Checkpoint Id",
      "type": "string"
    },
    "resumable": {
      "default": true,
      "title": "Resumable",
      "type": "boolean"
    },
    "executable": {
      "default": false,
      "title": "Executable",
      "type": "boolean"
