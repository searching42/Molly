      "type": "integer"
    },
    "consumed_steps": {
      "default": 0,
      "title": "Consumed Steps",
      "type": "integer"
    },
    "consumed_records": {
      "default": 0,
      "title": "Consumed Records",
      "type": "integer"
    },
    "consumed_cost_usd": {
      "default": 0.0,
