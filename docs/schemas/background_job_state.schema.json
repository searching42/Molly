          "default": null,
          "title": "Max Runtime Sec"
        },
        "max_steps": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Steps"
        },
        "max_records": {
          "anyOf": [
            {
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Records"
        },
        "max_cost_usd": {
          "anyOf": [
            {
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Cost Usd"
        }
      },
      "title": "BackgroundJobBudget",
      "type": "object"
    },
    "BackgroundJobCheckpoint": {
      "properties": {
