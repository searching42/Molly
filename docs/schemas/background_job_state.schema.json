    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "updated_at": {
      "title": "Updated At",
      "type": "string"
    },
    "budget": {
      "$ref": "#/$defs/BackgroundJobBudget"
    },
    "consumed_runtime_sec": {
      "default": 0,
