      "type": "string"
    },
    "project_id": {
      "default": "",
      "title": "Project Id",
      "type": "string"
    },
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "task_id": {
      "title": "Task Id",
      "type": "string"
    },
