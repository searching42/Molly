{
  "$defs": {
    "CriticDecision": {
      "properties": {
        "decision": {
          "title": "Decision",
          "type": "string"
        },
        "reason": {
          "title": "Reason",
          "type": "string"
        },
        "requires_user_approval": {
          "default": true,
          "title": "Requires User Approval",
          "type": "boolean"
        },
        "target_stage": {
          "default": "",
          "title": "Target Stage",
          "type": "string"
        },
        "suggested_tools": {
          "items": {
            "type": "string"
          },
          "title": "Suggested Tools",
          "type": "array"
        }
      },
      "required": [
        "decision",
        "reason"
      ],
      "title": "CriticDecision",
      "type": "object"
    },
    "CriticFinding": {
      "properties": {
        "finding_id": {
          "title": "Finding Id",
          "type": "string"
        },
        "severity": {
          "title": "Severity",
          "type": "string"
        },
        "category": {
          "title": "Category",
          "type": "string"
        },
        "summary": {
          "title": "Summary",
          "type": "string"
        },
        "evidence_refs": {
          "items": {
            "type": "string"
          },
          "title": "Evidence Refs",
          "type": "array"
        },
        "recommended_actions": {
          "items": {
            "type": "string"
          },
          "title": "Recommended Actions",
          "type": "array"
        }
      },
      "required": [
        "finding_id",
        "severity",
        "category",
        "summary"
      ],
      "title": "CriticFinding",
      "type": "object"
    }
  },
  "properties": {
    "run_id": {
      "title": "Run Id",
      "type": "string"
    },
    "project_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Project Id"
    },
    "goal": {
      "default": "",
      "title": "Goal",
      "type": "string"
    },
    "current_stage": {
      "title": "Current Stage",
      "type": "string"
    },
    "decision": {
      "$ref": "#/$defs/CriticDecision"
    },
    "findings": {
      "items": {
        "$ref": "#/$defs/CriticFinding"
      },
      "title": "Findings",
      "type": "array"
    },
    "risk_flags": {
      "items": {
        "type": "string"
      },
      "title": "Risk Flags",
      "type": "array"
    },
    "blocked_reasons": {
      "items": {
        "type": "string"
      },
      "title": "Blocked Reasons",
      "type": "array"
    },
    "recommended_next_actions": {
      "items": {
        "type": "string"
      },
      "title": "Recommended Next Actions",
      "type": "array"
    },
    "assumptions": {
      "items": {
        "type": "string"
      },
      "title": "Assumptions",
      "type": "array"
    },
    "executable": {
      "default": false,
      "title": "Executable",
      "type": "boolean"
    }
  },
  "required": [
    "run_id",
    "current_stage",
    "decision"
  ],
  "title": "CriticReview",
  "type": "object"
}
